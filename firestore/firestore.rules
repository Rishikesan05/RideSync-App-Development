rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Route fares - public read for active fares
    match /route_fares/{routeId} {
      allow read: if resource.data.active == true;
      allow write: if false;
    }

    // Users collection - auth users can read/create their own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Passengers collection
    match /passengers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Operators collection
    match /operators/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Bus registrations
    match /bus_registrations/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
